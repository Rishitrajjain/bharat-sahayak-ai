pip install streamlit


import streamlit as st
from eligibility_engine import find_eligible_schemes
from ai_engine import explain_schemes

st.title("🇮🇳 Bharat Sahayak AI")

income = st.number_input("वार्षिक आय (Annual Income)", value=150000)

occupation = st.selectbox(
"आपका पेशा",
["farmer","daily_worker","student","unemployed","any"]
)

state = st.text_input("राज्य")

if st.button("Find Schemes"):

    profile = {
        "income":income,
        "occupation":occupation,
        "state":state
    }

    schemes = find_eligible_schemes(profile)

    result = explain_schemes(profile, schemes)

    st.write(result)



